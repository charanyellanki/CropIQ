# CropIQ — local development environment variables
# Copy to .env (gitignored) and fill in values.

# USDA NASS Quick Stats API key (required for data acquisition).
# Free signup: https://quickstats.nass.usda.gov/api
NASS_API_KEY=

# NOAA CDO API token (fallback only; nClimGrid does not require auth).
# Free signup: https://www.ncdc.noaa.gov/cdo-web/token
NOAA_TOKEN=

# Optional: override MLflow tracking URI (defaults to file://<repo>/mlruns).
# MLFLOW_TRACKING_URI=

# Optional: log level (DEBUG, INFO, WARNING, ERROR). Default INFO.
# LOG_LEVEL=INFO
